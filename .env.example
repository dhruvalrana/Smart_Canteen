# SmartCanteen Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# DJANGO CONFIGURATION
# ============================================

# Secret key for Django (generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())')
SECRET_KEY=your-secret-key-here-change-this-in-production

# Debug mode (True for development, False for production)
DEBUG=True

# Allowed hosts (comma-separated, add your domain in production)
ALLOWED_HOSTS=127.0.0.1,localhost

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database engine: sqlite3 (default), postgresql
DATABASE_ENGINE=django.db.backends.sqlite3

# For SQLite (default):
DATABASE_NAME=db.sqlite3

# For PostgreSQL (uncomment and configure):
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=smartcanteen_db
# DATABASE_USER=smartcanteen_user
# DATABASE_PASSWORD=your_secure_password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Email backend - Choose one:
# For Development: Use console backend (OTPs print to Django console)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For Production with Gmail: Uncomment and configure the following block
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# For SendGrid (alternative):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your_sendgrid_api_key

# Default from email
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ============================================
# OTP CONFIGURATION
# ============================================

# OTP validity in minutes
OTP_VALIDITY_MINUTES=10

# OTP length (number of digits)
OTP_LENGTH=6

# Maximum OTP validation attempts
OTP_MAX_ATTEMPTS=3

# ============================================
# SECURITY SETTINGS
# ============================================

# HTTPS/SSL (set to True in production)
SECURE_SSL_REDIRECT=False

# Session cookie security
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# CORS settings (if needed)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# FILE UPLOADS
# ============================================

# Max file size for uploads (in bytes, default 5MB)
MAX_UPLOAD_SIZE=5242880

# Media files directory
MEDIA_ROOT=media/
MEDIA_URL=/media/

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Log file path
LOG_FILE=logs/smartcanteen.log

# ============================================
# PAGINATION
# ============================================

# Items per page for food list
FOOD_PER_PAGE=12

# Orders per page for user orders
ORDERS_PER_PAGE=10

# Items per page for admin
ADMIN_ITEMS_PER_PAGE=20

# ============================================
# OTHER SETTINGS
# ============================================

# Timezone
TIME_ZONE=UTC

# Language
LANGUAGE_CODE=en-us

# Site name
SITE_NAME=SmartCanteen

# Customer service email
CUSTOMER_SERVICE_EMAIL=support@smartcanteen.local